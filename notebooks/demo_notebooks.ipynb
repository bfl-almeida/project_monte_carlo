                "    mc_european_call_price,\n",
                "    mc_european_put_price,\n",
                "    mc_up_and_out_call_price,\n",
                ")\n",
                "from option_pricing.utils import convergence_table\n",
            ],
        },
        {
            "cell_type": "code",
            "execution_count": None,
            "metadata": {},
            "outputs": [],
            "source": [
                "S0 = 100\n",
                "K = 100\n",
                "B = 130\n",
                "T = 1.0\n",
                "r = 0.05\n",
                "sigma = 0.2\n",
            ],
        },
        {
            "cell_type": "code",
            "execution_count": None,
            "metadata": {},
            "outputs": [],
            "source": [
                "call_bs = bs_call_price(S0, K, T, r, sigma)\n",
                "put_bs = bs_put_price(S0, K, T, r, sigma)\n",
                "\n",
                "call_mc, call_se = mc_european_call_price(\n",
                "    S0=S0,\n",
                "    K=K,\n",
                "    T=T,\n",
                "    r=r,\n",
                "    sigma=sigma,\n",
                "    n_paths=100_000,\n",
                "    antithetic=True,\n",
                "    random_seed=42,\n",
                ")\n",
                "\n",
                "put_mc, put_se = mc_european_put_price(\n",
                "    S0=S0,\n",
                "    K=K,\n",
                "    T=T,\n",
                "    r=r,\n",
                "    sigma=sigma,\n",
                "    n_paths=100_000,\n",
                "    antithetic=True,\n",
                "    random_seed=42,\n",
                ")\n",
                "\n",
                "barrier_mc, barrier_se = mc_up_and_out_call_price(\n",
                "    S0=S0,\n",
                "    K=K,\n",
                "    B=B,\n",
                "    T=T,\n",
                "    r=r,\n",
                "    sigma=sigma,\n",
                "    n_paths=100_000,\n",
                "    n_steps=252,\n",
                "    antithetic=True,\n",
                "    random_seed=42,\n",
                ")\n",
                "\n",
                "print(f'Black-Scholes Call: {call_bs:.4f}')\n",
