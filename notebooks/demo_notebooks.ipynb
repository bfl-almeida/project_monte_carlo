                "print()\n",
                "print(f'Black-Scholes Put:  {put_bs:.4f}')\n",
                "print(f'Monte Carlo Put:    {put_mc:.4f}  | SE: {put_se:.4f}')\n",
                "print()\n",
                "print(f'Up-and-Out Call MC: {barrier_mc:.4f} | SE: {barrier_se:.4f}')\n",
            ],
